# Sunucu
PORT=3000
APP_URL=http://localhost:3000

# Güvenlik (üretimde güçlü rastgele değerler kullanın)
JWT_SECRET=degistir-guclu-rastgele-metin
ADMIN_PASSWORD=degistir-guclu-admin-sifresi

# PostgreSQL (docker compose ile AYNI şifreyi kullanın)
# NOT: copy .env.example .env yapmayın — mevcut .env'inizi silersiniz!
# Volume ilk kez oluşurken seçilen şifre kalıcıdır; değiştirmek için: npm run dev:down -v
DB_USER=patron
DB_HOST=localhost
DB_NAME=kavrulmus_db
DB_PASSWORD=changeme
DB_PORT=5432

# ── Gmail SMTP ──────────────────────────────────────────────
# 1. Google Hesap > Güvenlik > 2 Adımlı Doğrulama'yı açın
# 2. "Uygulama şifreleri" > Mail için 16 haneli şifre oluşturun
# 3. Aşağıyı doldurun (boş bırakırsanız site çalışır, mail gitmez)
EMAIL_USER=ornek@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
ADMIN_EMAIL=ornek@gmail.com
